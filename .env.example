# Private key for deploying/testing contracts
PRIVATE_KEY=your_private_key_here

# Secondary private key for multi-account testing
PRIVATE_KEY2=your_second_private_key_here

# Wallet address
PRIVATE_ADDRESS=your_address_here

# AES key for testnet (generated during COTI Snap onboarding)
PRIVATE_AES_KEY_TESTNET=your_aes_key_here

# Fee recipient address — where bridge fees are sent (required for deployment)
FEE_RECIPIENT=0xYourFeeRecipientAddress

# Rescue recipient address — where rescued funds are sent (required for deployment)
RESCUE_RECIPIENT=0xYourRescueRecipientAddress
